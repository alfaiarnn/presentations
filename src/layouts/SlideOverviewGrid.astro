---
import ProductCard from '../components/ProductCard.astro';

interface Product {
  name: string;
  fullName: string;
  description: string;
  status: 'active' | 'wip';
  badgeText: 'Em operação' | 'Em desenvolvimento';
  icon?: string;
}

interface Props {
  id: string;
  theme: string;
  eyebrow: string;
  title: string;
  subtitle: string;
  products: Product[];
  divider?: string;
}

const { id, theme, eyebrow, title, subtitle, products, divider } = Astro.props;
---

{divider && <div class={`section-divider${divider === 'brand' ? ' section-divider--brand' : ''}`}></div>}
<section id={id} class={`section section--${theme}`}>
  <div class="section-container">
    <span class="section-eyebrow">{eyebrow}</span>
    <h2 class="section-title">{title}</h2>
    <p class="section-subtitle">{subtitle}</p>

    <div class="cards-grid">
      {products.map((product) => (
        <ProductCard
          name={product.name}
          fullName={product.fullName}
          description={product.description}
          status={product.status}
          badgeText={product.badgeText}
          icon={product.icon}
        />
      ))}
    </div>
  </div>
</section>
