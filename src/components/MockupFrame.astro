---
interface Props {
  alt: string;
  src?: string;
  placeholderIcon?: string;
}

const { alt, src, placeholderIcon } = Astro.props;

// Default placeholder SVG for different product types
const placeholderSvgs: Record<string, string> = {
  default: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="m3 16 5-5 4 4 4-6 5 7"/>',
  chart: '<rect x="3" y="3" width="18" height="18" rx="2"/><polyline points="7 14 11 10 15 13 19 8"/>',
  database: '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>',
};

const svgContent = placeholderSvgs[placeholderIcon || 'default'] || placeholderSvgs.default;
---

<div class="mockup-frame">
  <div class="mockup-frame__bar">
    <span class="mockup-frame__dot"></span>
    <span class="mockup-frame__dot"></span>
    <span class="mockup-frame__dot"></span>
  </div>

  {src ? (
    <img src={src} alt={alt} loading="lazy" />
  ) : (
    <div class="mockup-placeholder">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" set:html={svgContent} />
      <span>{alt}</span>
    </div>
  )}
</div>
