---
interface Props {
  label: string;
  icon?: string;
}

const { label, icon } = Astro.props;

// Map icon names to simple SVG paths
const icons: Record<string, string> = {
  'bar-chart': '<path d="M3 3v18h18"/><rect x="7" y="10" width="3" height="8"/><rect x="14" y="6" width="3" height="12"/>',
  'activity': '<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>',
  'trending-up': '<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>',
};

const svgContent = icon && icons[icon] ? icons[icon] : null;
---

<span class="chip">
  {svgContent && (
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={svgContent} />
  )}
  {label}
</span>
