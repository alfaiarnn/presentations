---
interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description, icon } = Astro.props;

const icons: Record<string, string> = {
  'monitor': '<rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>',
  'activity': '<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>',
  'bell': '<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>',
};

const svgContent = icon && icons[icon] ? icons[icon] : null;
---

<div class="pillar-card">
  {svgContent && (
    <div class="pillar-card__icon">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2E7D32" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={svgContent} />
    </div>
  )}
  <h3 class="pillar-card__title">{title}</h3>
  <p class="pillar-card__desc">{description}</p>
</div>
