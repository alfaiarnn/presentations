---
// src/components/PortalMotion.astro
---
<div class="cinematic-container" id="portal-infinite-stage">
  <svg class="data-feed" viewBox="0 0 800 450">
    <path class="feed-line" id="feed-line-path" d="M -50 225 L 250 225" />
  </svg>
  <div class="portal-window" id="portal-window-el">
    <div class="wire-header">
      <div class="wire-block skeleton logo-block"></div>
      <div class="wire-block skeleton menu-block"></div>
    </div>
    <div class="wire-body">
      <div class="wire-sidebar">
        <div class="wire-block skeleton side-item"></div>
        <div class="wire-block skeleton side-item"></div>
        <div class="wire-block skeleton side-item"></div>
      </div>
      <div class="wire-content">
        <div class="header-blocks">
          <div class="wire-block skeleton title-block"></div>
          <div class="wire-block skeleton subtitle-block"></div>
        </div>
        <div class="kpi-grid">
          <div class="wire-block skeleton kpi-box"></div>
          <div class="wire-block skeleton kpi-box"></div>
          <div class="wire-block skeleton kpi-box"></div>
        </div>
        <div class="chart-card">
          <div class="chart-bars">
            <div class="bar skeleton bar-1"></div>
            <div class="bar skeleton bar-2"></div>
            <div class="bar skeleton bar-3"></div>
            <div class="bar skeleton bar-4"></div>
            <div class="bar skeleton bar-5"></div>
          </div>
        </div>
      </div>
    </div>
    <div class="sync-flash"></div>
  </div>
</div>

<style>
  .cinematic-container {
    width: 100%; height: 100%; min-height: 450px; position: relative;
    display: flex; justify-content: center; align-items: center;
    background: radial-gradient(circle at center, var(--bg-surface, #0f172a) 0%, #020617 100%);
    border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); overflow: hidden;
  }
  .data-feed { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 1; }
  .feed-line { fill: none; stroke: var(--color-success, #10b981); stroke-width: 4px; stroke-linecap: round; stroke-dasharray: 4 30; filter: drop-shadow(0 0 8px var(--color-success, #10b981)); opacity: 0; }
  .portal-window {
    width: 600px; height: 360px;
    background: rgba(15, 23, 42, 0.6); border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px; backdrop-filter: blur(12px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.6), inset 0 0 20px rgba(255,255,255,0.02);
    display: flex; flex-direction: column; overflow: hidden; position: relative; z-index: 5;
  }
  .wire-block { border-radius: 4px; background-color: rgba(148, 163, 184, 0.15); }
  .wire-header { height: 40px; border-bottom: 1px solid rgba(255, 255, 255, 0.1); display: flex; align-items: center; justify-content: space-between; padding: 0 16px; background: rgba(0,0,0,0.2); }
  .logo-block { width: 80px; height: 12px; }
  .menu-block { width: 24px; height: 12px; }
  .wire-body { display: flex; flex: 1; padding: 16px; gap: 16px; overflow: hidden; }
  .wire-sidebar { display: flex; flex-direction: column; gap: 12px; width: 40px; }
  .side-item { width: 100%; height: 24px; border-radius: 6px; }
  .wire-content { flex: 1; display: flex; flex-direction: column; gap: 16px; min-width: 0; }
  .header-blocks { display: flex; flex-direction: column; gap: 8px; }
  .title-block { width: 60%; height: 14px; background-color: rgba(148, 163, 184, 0.4); }
  .subtitle-block { width: 40%; height: 8px; background-color: rgba(148, 163, 184, 0.4); }
  .kpi-grid { display: flex; flex-wrap: wrap; gap: 12px; }
  .kpi-box { flex: 1 1 25%; min-width: 60px; height: 50px; border-radius: 8px; }
  .chart-card { flex: 1; border: 1px solid rgba(255,255,255,0.05); border-radius: 8px; padding: 12px; display: flex; align-items: flex-end; }
  .chart-bars { display: flex; gap: 8px; width: 100%; height: 100%; align-items: flex-end; }
  .bar { flex: 1; border-radius: 4px 4px 0 0; transform-origin: bottom; background-color: rgba(148, 163, 184, 0.15); }
  .skeleton {
    background-image: linear-gradient(90deg, rgba(255,255,255,0.01) 25%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0.01) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite linear;
  }
  @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
  .sync-flash { position: absolute; inset: 0; background: rgba(16, 185, 129, 0.15); pointer-events: none; opacity: 0; mix-blend-mode: screen; }
</style>

<script>
  import { initPortalMotion } from '../../scripts/animations';

  document.addEventListener('astro:page-load', () => { initPortalMotion(); });

  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    setTimeout(initPortalMotion, 100);
  } else {
    document.addEventListener('DOMContentLoaded', initPortalMotion);
  }
</script>
